# ضع مفاتيح Groq الخاصة بك هنا (يمكنك الحصول عليها من https://console.groq.com/keys)
# لا يجب أن تكون كل الخانات معبأة، لكن كل ما زاد عدد المفاتيح كل ما قلّ احتمال الوصول لحد الاستخدام (rate limit)

GROQ_API_KEY_1=
GROQ_API_KEY_2=
GROQ_API_KEY_3=
GROQ_API_KEY_4=
GROQ_API_KEY_5=
GROQ_API_KEY_6=
GROQ_API_KEY_7=
GROQ_API_KEY_8=
GROQ_API_KEY_9=
GROQ_API_KEY_10=

# اسم الموديل المستخدم من Groq (يمكن تغييره)
GROQ_MODEL=llama-3.3-70b-versatile

# المنفذ الذي يشتغل عليه السيرفر
PORT=3000

# ---------------- إعدادات الأمان ----------------

# كلمة مرور لحماية الموقع بالكامل (مهم جدًا قبل نشره للعامة!)
# لو تركتها فارغة، الموقع يفتح بدون تسجيل دخول (مناسب فقط للتجربة المحلية)
SITE_PASSWORD=

# مفتاح سري لتشفير جلسات تسجيل الدخول — غيّريه لأي نص عشوائي طويل قبل النشر
# يمكنك توليد واحد بالأمر: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# اجعليها true فقط عندما يعمل موقعك فعليًا خلف HTTPS (بعد النشر على استضافة حقيقية)
FORCE_HTTPS=false
